{
  "env": {
    "LLAMACPP_API_KEY": "llamacpp-local"
  },
  "gateway": {
    "mode": "local",
    "controlUi": {
      "allowedOrigins": [
        "http://127.0.0.1:18789",
        "http://localhost:18789"
      ]
    }
  },
  "tools": {
    "exec": {
      "host": "gateway",
      "security": "full"
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "llamacpp/qwen3.5-35b-a3b",
        "fallbacks": []
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "llamacpp": {
        "baseUrl": "http://host.docker.internal:21434",
        "apiKey": "llamacpp-local",
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen3.5-35b-a3b",
            "name": "Qwen3.5 35B A3B (llama.cpp)",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "channels": {
    "slack": {
      "enabled": true
    }
  },
  "skills": {
    "entries": {
      "github": { "enabled": true },
      "slack": { "enabled": true },
      "confluence-read": { "enabled": true },
      "jira-read": { "enabled": true }
    }
  }
}
